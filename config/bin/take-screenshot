#!/usr/bin/env bash

screenshots_dir="${HOME}/Pictures/Screenshots"
screenshots_file="${screenshots_dir}/$(date +'%Y-%m-%d %H-%M-%S').png"

[[ ! -d "${screenshots_dir}" ]] && mkdir -p "${screenshots_dir}"
[[ -z "${screenshots_file}" ]] && exit 1

case "${1}" in
"--region")
  grim -g "$(slurp)" "${screenshots_file}" || exit 1
  dunstify -a "Screenshot" -r 9993 -i "${screenshots_file}" "Screenshot" "Saved to ${screenshots_file}."
  ;;
"--window")
  grim -g "$(hyprctl -j activewindow | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')" "${screenshots_file}" || exit 1
  dunstify -a "Screenshot" -r 9993 -i "${screenshots_file}" "Screenshot" "Saved to ${screenshots_file}."
  ;;
*)
  grim "${screenshots_file}" || exit 1
  dunstify -a "Screenshot" -r 9993 -i "${screenshots_file}" "Screenshot" "Saved to ${screenshots_file}."
  ;;
esac
